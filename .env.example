# Database
# SECURITY: Use strong password, enable SSL in production
# Generate password: openssl rand -base64 32
POSTGRES_USER=fsrs
POSTGRES_PASSWORD=
POSTGRES_DB=fsrs
# Use require or verify-full when connecting to a remote Postgres instance with TLS.
DATABASE_SSLMODE=disable

# JWT Secret
# SECURITY: Must be at least 32 characters, use cryptographically random value
# Generate: openssl rand -base64 32
JWT_SECRET=

# Server
PORT=8080

# Security
# Set to "production" in production to enforce strict secret requirements
ENV=production
# Production requires HTTPS termination with valid certs mounted at ./certs
SECURE_COOKIES=true
# Comma-separated origins allowed to access the API with credentials.
# Default production value is https://fsrs.ziyang.li
CORS_ORIGINS=https://fsrs.ziyang.li
# Set to true only when running behind a trusted reverse proxy that sets X-Real-IP.
TRUST_PROXY_HEADERS=true

# SECURITY CHECKLIST:
# 1. Change POSTGRES_PASSWORD to a strong random value
# 2. Change JWT_SECRET to a random 32+ character string
# 3. Never commit .env file to version control
# 4. Use HTTPS in production (configured via nginx + certbot)
# 5. Provide ./certs/fullchain.pem and ./certs/privkey.pem before running docker-compose.yml
